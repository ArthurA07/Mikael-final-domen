{
  "name": "mental-arithmetic-trainer",
  "version": "1.0.0",
  "description": "Интерактивный тренажёр ментальной арифметики с абакусом",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "dev:mem": "concurrently \"npm run server:mem\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "server:mem": "cd server && npm run dev:mem",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "start": "cd server && npm start",
    "install-all": "npm install && cd server && npm install && cd ../client && npm install"
  },
  "keywords": ["mental arithmetic", "abacus", "soroban", "education", "math"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
} 