PORT=5000
MONGODB_URI=mongodb://localhost:27017/mental-arithmetic
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRE=30d
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
PUBLIC_APP_URL=http://localhost:3001

# Ограничение бесплатного доступа для гостей (по IP)
FREE_ACCESS_EXERCISES_LIMIT=5

# SMTP (для восстановления пароля). Заполните для продакшена/стендов.
# Пример для Gmail (требуется App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="Mikael Trainer <no-reply@mikael-final.app>"